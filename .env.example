# Server
PORT=3000
HOST=0.0.0.0
BASE_URL=http://internal.localhost

# Limits
MAX_FILE_SIZE=10485760    # 10MB in bytes
REQUEST_TIMEOUT=30000     # 30 seconds in ms

# URL Checker
URL_CHECK_TIMEOUT=15000   # 15 seconds in ms

# Logging
LOG_LEVEL=info            # trace, debug, info, warn, error, fatal
